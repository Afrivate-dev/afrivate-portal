# E2E tests run against Supabase — copy to .env.test.local and fill in values.
# Never commit .env.test.local (gitignored).

VITE_USE_SUPABASE_AUTH=true
VITE_USE_SUPABASE_DATA=true

# Supabase project (same as production .env)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Test account credentials — create real users in Supabase Auth; do not commit passwords.
E2E_STAFF_EMAIL=
E2E_STAFF_PASSWORD=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
# Optional: inactive user for Request access flow tests
E2E_PENDING_EMAIL=
E2E_PENDING_PASSWORD=
