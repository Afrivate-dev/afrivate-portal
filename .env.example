# ─── Supabase project credentials ─────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Authentication mode ───────────────────────────────────────────────────────
# Set to true to use Supabase Authentication (email/password login, invites,
# password reset). Requires valid VITE_SUPABASE_* values above.
# Leave unset or false to run in local/demo mode with mock users.
VITE_USE_SUPABASE_AUTH=true

# ─── Data mode ─────────────────────────────────────────────────────────────────
# Set to true to load portal data (tasks, announcements, leave, onboarding, etc.)
# from Supabase tables instead of localStorage. Requires VITE_USE_SUPABASE_AUTH=true
# and the SQL migrations applied (see supabase/migrations/).
# VITE_USE_SUPABASE_DATA=false
