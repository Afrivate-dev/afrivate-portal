# ─── Supabase project credentials ─────────────────────────────────────────────
# Use the JWT anon key from Dashboard → Project Settings → API (starts with eyJ).
# Do not use sb_publishable_ keys — profile loading will fail.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Authentication mode ───────────────────────────────────────────────────────
# Set to true to use Supabase Authentication (email/password login, invites,
# password reset). Requires valid VITE_SUPABASE_* values above.
VITE_USE_SUPABASE_AUTH=true

# ─── Data mode ─────────────────────────────────────────────────────────────────
# Set to true to load portal data (tasks, announcements, leave, notes, etc.)
# from Supabase tables instead of localStorage. Requires VITE_USE_SUPABASE_AUTH=true
# and all SQL migrations applied (see supabase/migrations/).
VITE_USE_SUPABASE_DATA=true

# ─── External integrations (optional) ───────────────────────────────────────────
# Media upload endpoint for avatars and announcement attachments
# VITE_MEDIA_UPLOAD_URL=https://www.afrivate.org/portal-media/upload.php
# External team calendar JSON feed
# VITE_TEAM_CALENDAR_JSON_URL=
# Google Calendar embed iframe URL
# VITE_GOOGLE_CALENDAR_EMBED_URL=

# ─── Supabase Edge Function secrets (set in Supabase Dashboard, not here) ───────
# SITE_URL=https://portal.afrivate.org
# ALLOWED_EMAIL_DOMAIN=   (leave empty to allow any email on admin invites)
